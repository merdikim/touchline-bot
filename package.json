{
  "name": "touchline-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "dev": "wrangler dev",
    "dev:telegram-poll": "tsx scripts/telegram-poll-webhook.ts",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply touchline --local",
    "db:migrate:remote": "wrangler d1 migrations apply touchline --remote",
    "setup:txline": "tsx scripts/txline-setup.ts",
    "smoke:txline": "tsx scripts/txline-smoke.ts"
  },
  "dependencies": {
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "bs58": "^6.0.0",
    "drizzle-orm": "^0.38.4",
    "grammy": "^1.34.0",
    "hono": "^4.6.17",
    "openai": "^6.45.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260701.0",
    "@types/node": "^26.1.0",
    "drizzle-kit": "^0.30.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "wrangler": "^4.23.0"
  }
}
